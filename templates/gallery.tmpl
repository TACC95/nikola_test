## -*- coding: utf-8 -*-
<%! import json %>
<%! from urllib.parse import quote %>
<%inherit file="base.tmpl"/>
<%namespace name="comments" file="comments_helper.tmpl"/>
<%namespace name="ui" file="ui_helper.tmpl"/>
<%namespace name="post_helper" file="post_helper.tmpl"/>
<%block name="sourcelink"></%block>

<%block name="extra_head">
${parent.extra_head()}
<style type="text/css">
    #gallery_container {
        position: relative;
    }
    .image-block {
        position: absolute;
    }
    %if photo_array and post and post.meta('music'):
    /* 单个相册页底部音乐播放器 */
    body.has-gallery-player {
        padding-bottom: 80px;
    }
    #gallery-player {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: rgba(30, 30, 35, 0.96);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        z-index: 1000;
        box-shadow: 0 -2px 12px rgba(0,0,0,0.35);
        font-size: 14px;
    }
    .player-info {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 220px;
        flex-shrink: 0;
    }
    .player-cover {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #444, #222);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }
    .player-title {
        font-size: 14px;
        color: #fff;
        margin-bottom: 4px;
    }
    .player-artist {
        font-size: 12px;
        color: #999;
    }
    .player-controls {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-shrink: 0;
    }
    .player-btn {
        background: none;
        border: none;
        color: #ddd;
        font-size: 20px;
        cursor: pointer;
        padding: 4px 8px;
        transition: color 0.2s;
    }
    .player-btn:hover {
        color: #fff;
    }
    .player-play {
        font-size: 28px;
    }
    .player-progress {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 1;
        max-width: 500px;
        margin: 0 24px;
    }
    .player-progress input[type="range"] {
        flex: 1;
        height: 4px;
        -webkit-appearance: none;
        background: #555;
        border-radius: 2px;
        outline: none;
    }
    .player-progress input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 12px;
        height: 12px;
        background: #fff;
        border-radius: 50%;
        cursor: pointer;
    }
    .player-time {
        font-size: 12px;
        color: #aaa;
        min-width: 38px;
        text-align: center;
    }
    .player-volume {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 140px;
        flex-shrink: 0;
    }
    .player-volume input[type="range"] {
        flex: 1;
        height: 4px;
        -webkit-appearance: none;
        background: #555;
        border-radius: 2px;
        outline: none;
    }
    .player-volume input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 10px;
        height: 10px;
        background: #fff;
        border-radius: 50%;
        cursor: pointer;
    }
    @media (max-width: 768px) {
        #gallery-player {
            padding: 0 12px;
        }
        .player-volume {
            display: none;
        }
        .player-info {
            width: auto;
            max-width: 120px;
        }
        .player-progress {
            margin: 0 12px;
        }
    }
    %endif
</style>
%if len(translations) > 1:
    %for langname in translations.keys():
         %if langname != lang:
             <link rel="alternate" hreflang="${langname}" href="${_link('gallery', gallery_path, langname)}">
         %endif
    %endfor
%endif
%if post:
    ${post_helper.open_graph_metadata(post)}
    ${post_helper.twitter_card_information(post)}
%endif
</%block>

<%block name="content">
    ${ui.breadcrumbs(crumbs)}
    %if title:
    <h1>${title|h}</h1>
    %endif
    %if post:
    <div class="gallery-description">
        ${post.text()}
    </div>
    %endif

    %if folders:
    <div class="gallery-grid">
        % for item in folders:
        <%
            folder = item[0]
            ftitle = item[1]
            fpost = item[2] if len(item) > 2 else None
        %>
        <a href="${folder}" class="gallery-card">
            % if fpost and fpost.previewimage:
            <div class="gallery-card-image">
                <img src="${fpost.previewimage}" alt="${ftitle|h}" loading="lazy">
            </div>
            % else:
            <div class="gallery-card-image gallery-card-placeholder">
                <span>📷</span>
            </div>
            % endif
            <div class="gallery-card-body">
                <h2>${ftitle|h}</h2>
            </div>
        </a>
        % endfor
    </div>
    %endif

<div id="gallery_container"></div>
%if photo_array:
<noscript>
<ul class="thumbnails">
    %for image in photo_array:
        <li><a href="${image['url']}" class="thumbnail image-reference" title="${image['title']|h}">
            <img src="${image['url_thumb']}" alt="${image['title']|h}" loading="lazy" /></a>
    %endfor
</ul>
</noscript>

%if post and post.meta('music'):
<%
    music_meta = post.meta('music')
    music_files = [f.strip() for f in music_meta.split(',') if f.strip()]
    playlist = []
    for f in music_files:
        name = f.split('/')[-1]
        track_title = name.rsplit('.', 1)[0] if '.' in name else name
        # 把绝对路径 /assets/... 转为相对路径 ../../assets/...，兼容子目录部署
        if f.startswith('/'):
            relative_src = '../../' + f.lstrip('/')
        else:
            relative_src = f
        encoded_src = quote(relative_src, safe='/')
        playlist.append({'src': encoded_src, 'title': track_title})
%>
<div id="gallery-player">
    <div class="player-info">
        <div class="player-cover">🎵</div>
        <div class="player-meta">
            <div class="player-title" id="player-title">-</div>
            <div class="player-artist" id="player-artist">${len(playlist)} 首歌曲</div>
        </div>
    </div>
    <div class="player-controls">
        <button class="player-btn" id="player-prev" title="上一首">⏮</button>
        <button class="player-btn player-play" id="player-play" title="播放/暂停">▶</button>
        <button class="player-btn" id="player-next" title="下一首">⏭</button>
    </div>
    <div class="player-progress">
        <span class="player-time" id="player-current">0:00</span>
        <input type="range" id="player-seek" value="0" min="0" max="100">
        <span class="player-time" id="player-duration">0:00</span>
    </div>
    <div class="player-volume">
        <span>🔊</span>
        <input type="range" id="player-volume" value="80" min="0" max="100">
    </div>
    <audio id="player-audio" preload="metadata"></audio>
</div>
<script>
    window.galleryPlaylist = ${json.dumps(playlist)};
</script>
%endif
%endif
%if site_has_comments and enable_comments:
    ${comments.comment_form(None, permalink, title)}
%endif
</%block>

<%block name="extra_js">
<script src="/assets/js/justified-layout.min.js"></script>
<script src="/assets/js/gallery.min.js"></script>
<script>
var jsonContent = ${photo_array_json};
var thumbnailSize = ${thumbnail_size};
renderGallery(jsonContent, thumbnailSize);
window.addEventListener('resize', function(){renderGallery(jsonContent, thumbnailSize)});

%if photo_array and post and post.meta('music'):
// 底部音乐播放器（仅在单相册页且配置了 music 元数据时生效）
(function() {
    const playlist = window.galleryPlaylist;
    if (!playlist || !playlist.length) return;

    document.body.classList.add('has-gallery-player');

    const audio = document.getElementById('player-audio');
    const playBtn = document.getElementById('player-play');
    const prevBtn = document.getElementById('player-prev');
    const nextBtn = document.getElementById('player-next');
    const seek = document.getElementById('player-seek');
    const volume = document.getElementById('player-volume');
    const currentEl = document.getElementById('player-current');
    const durationEl = document.getElementById('player-duration');
    const titleEl = document.getElementById('player-title');

    let currentIndex = 0;

    function formatTime(t) {
        if (!t || isNaN(t)) return '0:00';
        const m = Math.floor(t / 60);
        const s = Math.floor(t % 60).toString().padStart(2, '0');
        return m + ':' + s;
    }

    function loadTrack(index) {
        currentIndex = index;
        const track = playlist[currentIndex];
        audio.src = track.src;
        titleEl.textContent = track.title;
        durationEl.textContent = '0:00';
        seek.value = 0;
        currentEl.textContent = '0:00';
        playBtn.textContent = '▶️';
    }

    playBtn.addEventListener('click', function() {
        if (audio.paused) {
            if (!audio.src) loadTrack(0);
            audio.play().catch(function(e) {
                console.log('播放失败，请检查音频文件是否存在:', e);
            });
            playBtn.textContent = '⏸';
        } else {
            audio.pause();
            playBtn.textContent = '▶️';
        }
    });

    prevBtn.addEventListener('click', function() {
        let index = currentIndex - 1;
        if (index < 0) index = playlist.length - 1;
        loadTrack(index);
        audio.play().catch(function() {});
        playBtn.textContent = '⏸';
    });

    nextBtn.addEventListener('click', function() {
        let index = currentIndex + 1;
        if (index >= playlist.length) index = 0;
        loadTrack(index);
        audio.play().catch(function() {});
        playBtn.textContent = '⏸';
    });

    audio.addEventListener('timeupdate', function() {
        if (audio.duration) {
            seek.value = (audio.currentTime / audio.duration) * 100;
            currentEl.textContent = formatTime(audio.currentTime);
        }
    });

    audio.addEventListener('loadedmetadata', function() {
        durationEl.textContent = formatTime(audio.duration);
    });

    audio.addEventListener('ended', function() {
        nextBtn.click();
    });

    function seekAudio() {
        if (audio.duration) {
            audio.currentTime = (seek.value / 100) * audio.duration;
        }
    }
    seek.addEventListener('input', seekAudio);
    seek.addEventListener('change', seekAudio);

    volume.addEventListener('input', function() {
        audio.volume = volume.value / 100;
    });

    audio.volume = volume.value / 100;
    loadTrack(0);
})();
%endif
</script>
</%block>
